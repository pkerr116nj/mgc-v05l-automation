{
  "provider_selection": {
    "historical_research": [
      "databento",
      "schwab_market_data"
    ],
    "live_market_data": [
      "schwab_market_data",
      "databento"
    ],
    "execution_truth": [
      "schwab_execution"
    ]
  },
  "data_source_precedence": {
    "historical_research": {
      "1m": [
        "historical_1m_canonical",
        "databento_historical",
        "schwab_history"
      ],
      "5m": [
        "historical_5m_canonical",
        "internal",
        "resampled_1m_to_5m",
        "schwab_history"
      ],
      "10m": [
        "historical_10m_canonical",
        "resampled_1m_to_10m",
        "historical_1m_canonical"
      ]
    },
    "live_market_data": {
      "1m": [
        "schwab_live_poll",
        "databento_live",
        "historical_1m_canonical",
        "schwab_history"
      ]
    }
  },
  "schwab_market_data": {
    "config_path": "config/schwab.local.json",
    "provenance_tag": "schwab_market_data",
    "canonical_data_source_by_timeframe": {
      "1m": "historical_1m_canonical",
      "5m": "historical_5m_canonical"
    }
  },
